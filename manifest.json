{
  "name": "cortex-plugin-multi-repo",
  "version": "1.0.1",
  "description": "Multi-Repo Change Orchestrator \u2014 Coordinate changes across repos: branches, API versions, cross-repo PRs, merge ordering",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-multi-repo",
  "homepage": "https://cortexprism.io/marketplace/plugins/multi-repo",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
  "tools": [
    {
      "name": "multirepo_create_branches",
      "description": "Create branches across repos",
      "params": []
    },
    {
      "name": "multirepo_track_prs",
      "description": "Track cross-repository PRs",
      "params": []
    },
    {
      "name": "multirepo_plan_merge",
      "description": "Plan merge order to avoid breakage",
      "params": []
    },
    {
      "name": "multirepo_sync_versions",
      "description": "Ensure consistent API versions across repos",
      "params": []
    }
  ],
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=0.51.0"
  },
  "aiDisclosure": {
    "tools": [
      "Kilo (DeepSeek) \u2014 batch scaffold"
    ],
    "humanReview": true
  }
}
